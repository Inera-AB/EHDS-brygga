       ] ;
       fhir:name [ fhir:v "Legitimationsnummer (Socialstyrelsen)" ] ;
       fhir:description [ fhir:v "Legitimationsnummer (OID 1.2.752.116.3.1.1) utfärdat av Socialstyrelsen för legitimerade yrkesgrupper inom hälso- och sjukvård. Förekommer i Provenance-resurser för vård- och behandlingsansvariga." ] ;
       fhir:example [
