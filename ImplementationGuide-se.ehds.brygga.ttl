         ]
       ] ) ;
       fhir:reference [
         fhir:link <https://fhir.inera.se/NamingSystem/NsSamordningsnummer> ;
         fhir:reference [ fhir:v "NamingSystem/NsSamordningsnummer" ]
       ] ;
       fhir:name [ fhir:v "Samordningsnummer" ] ;
       fhir:description [ fhir:v "Samordningsnummer (OID 1.2.752.129.2.1.3.3) utfärdat av Skatteverket. Kanonisk URI enligt HL7 Sweden basprofiler-r4." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
