         ]
       ] ) ;
       fhir:reference [
         fhir:link <https://fhir.inera.se/StructureDefinition/ext-asserted-date> ;
         fhir:reference [ fhir:v "StructureDefinition/ext-asserted-date" ]
       ] ;
       fhir:name [ fhir:v "Asserted Date" ] ;
       fhir:description [ fhir:v "Administrativt datum när diagnosen registrerades kliniskt (author-time).\nMappas från EPS-extensionen extension:assertedDate i GetDiagnosis.\nSkiljer sig från recordedDate (systemtidsstämpel) och onsetDateTime (klinisk debut)." ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
