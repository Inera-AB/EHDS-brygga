       ] ;
       fhir:name [ fhir:v "ICD-10 (International)" ] ;
       fhir:description [ fhir:v "ICD-10 internationell version (OID 2.16.840.1.113883.6.3) utgiven av WHO. Används när diagnoskodsystemets OID inte är det svenska (1.2.752.116.1.1.1.1.3)." ] ;
